# Copy to `.env` at repo root.

# AI (optional for local stub responses in LuffaWorker / full routing in RouterAgent)
GEMINI_API_KEY=

# Chain — local Hardhat defaults if unset
ENDLESS_RPC_URL=http://127.0.0.1:8545
ENDLESS_CHAIN_ID=31337
DEPLOYER_PRIVATE_KEY=

# Backend
BACKEND_PORT=3001

# Subscribe to TaskPosted / TaskAssigned on-chain (recommended when using wallet-based task posts from the UI).
# `start.bat` sets this for you. Set to `false` to reduce noise if no RPC is running.
ENABLE_CHAIN_EVENTS=true

# Luffa bot API (optional — IM notifications fail silently without secrets)
LUFFA_BOT1_SECRET=
LUFFA_BOT2_SECRET=
LUFFA_BOT3_SECRET=
LUFFA_BOT1_UID=
LUFFA_BOT2_UID=
LUFFA_BOT3_UID=

# Frontend (optional overrides)
# VITE_API_BASE_URL=http://localhost:3001
# VITE_WS_URL=ws://localhost:3001
