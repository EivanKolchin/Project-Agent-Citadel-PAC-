{
  "name": "internet-of-agents",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:reset": "kill-port 3001 5173 8545 && npm run dev",
    "deploy:contracts": "npm run deploy --workspace=contracts",
    "seed": "node scripts/seed.js",
    "demo": "node scripts/demo.js",
    "demo:agent": "ts-node packages/agents/examples/researchAgent.ts"
  },
  "dependencies": {
    "ethers": "^6.11.1",
    "kill-port": "^2.0.1",
    "puppeteer": "^24.40.0"
  }
}
